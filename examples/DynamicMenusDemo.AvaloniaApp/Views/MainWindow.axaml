<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:DynamicMenusDemo.AvaloniaApp.ViewModels"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:dynmenus="using:DynamicMenus.Controls"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		x:Class="DynamicMenusDemo.AvaloniaApp.Views.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		Icon="/Assets/avalonia-logo.ico"
		Title="DynamicMenusDemo.AvaloniaApp">

	<Design.DataContext>
		<!-- This only sets the DataContext for the previewer in an IDE,
		to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
		<vm:MainWindowViewModel/>
	</Design.DataContext>


	<DockPanel>

		<CommandBar DockPanel.Dock="Top"
					IsDynamicOverflowEnabled="True"
					PrimaryCommands="{Binding FileMenu, Converter={x:Static dynmenus:CommandBarConverter.Default}}"
					SecondaryCommands="{Binding EditMenu, Converter={x:Static dynmenus:CommandBarConverter.Default}}">

			<CommandBar.Content>
				<Menu>
					<dynmenus:DynamicMenuItem Header="File" ItemsSource="{Binding FileMenu}" />
					<dynmenus:DynamicMenuItem Header="Edit" ItemsSource="{Binding EditMenu}" />
					<dynmenus:DynamicMenuItem Header="About" ItemsSource="{Binding AboutMenu}" />
				</Menu>
			</CommandBar.Content>

		</CommandBar>

		<StackPanel Margin="4">

			<GroupBox Header="Menus">

				<WrapPanel>

					<Label Content="Context Menu (right click)">
						<Label.ContextMenu>
							<dynmenus:DynamicContextMenu ItemsSource="{Binding EditMenu}" />
						</Label.ContextMenu>
					</Label>

					<Button Content="Flyout menu (left click)">
						<Button.Flyout>
							<dynmenus:DynamicMenuFlyout ItemsSource="{Binding EditMenu}" />
						</Button.Flyout>
					</Button>
				
				</WrapPanel>		
				
			</GroupBox>		


			<GroupBox Header="States">

				<WrapPanel>

					<GroupBox Header="Clipboard text">
						<TextBox Text="{Binding ClipboardText}" />		
					</GroupBox>					

					<GroupBox Header="Option1">
						<TextBlock Text="{Binding Option1}" />	
					</GroupBox>

				</WrapPanel>

			</GroupBox>		

		</StackPanel>

	</DockPanel>

</Window>
